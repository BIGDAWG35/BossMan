# BossMan Environment Variables
# Copy this file to .env and fill in your local values.
# NEVER commit .env or any file containing real secrets.

# =============================================================================
# VAULT & KNOWLEDGE
# =============================================================================
OBSIDIAN_VAULT_PATH=/path/to/local/obsidian-vault
KNOWLEDGE_BASE=./knowledge

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=BIGDAWG35
DEFAULT_BRANCH=main

# =============================================================================
# LBC35 INFRASTRUCTURE
# =============================================================================
LBC35_HOST=192.168.x.x
LBC35_SSH_KEY=~/.ssh/lbc35_ed25519
LBC35_PORTS=3001,3100,5050,8090,8100,8102,8104,8110,8130,8140,8020

# =============================================================================
# HERMES AGENT
# =============================================================================
HERMES_CONFIG_PATH=~/.hermes/config.yaml
HERMES_LOG_LEVEL=info
HERMES_MAX_CONCURRENT_JOBS=4

# =============================================================================
# NOTIFICATIONS
# =============================================================================
NOTIFY_TELEGRAM=true
TELEGRAM_BOT_TOKEN=

# =============================================================================
# SERVICE AUTH (per-service, add as needed)
# =============================================================================
# SERVICE_A_API_KEY=
# SERVICE_B_CLIENT_SECRET=
# AUTH_SERVICE_JWT_SECRET=
# CACHE_REDIS_PASSWORD=
